{
  "extends": "@ivangabriele/eslint-config-typescript-react",
  "env": {
    "browser": true,
    "node": false
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "extraFileExtensions": [".cjs"],
    "project": "./tsconfig.json"
  },
  "ignorePatterns": ["/build/", "/packages/", "/src-tauri/"],
  "rules": {
    "react/jsx-props-no-spreading": "off",
    "react/react-in-jsx-scope": "off"
  },
  "overrides": [
    {
      "files": ["scripts/**/*.js"],
      "env": {
        "browser": false,
        "node": true
      }
    }
  ]
}
